# Full PostgreSQL connection string used in production.
DATABASE_URL="postgres://user:password@host:port/dbname"


# -----------------------------------------
# PROXY HOPS (optional)
# -----------------------------------------
# The number of reverse-proxy hops to trust when determining
# a client's real IP address for rate limiting purposes.
# Used by Express's "trust proxy" setting together with
# express-rate-limit. Defaults to 3 if not set.
# Increase this value if your app sits behind multiple proxies
# (e.g. load balancer + CDN).
PROXY_HOPS=3
